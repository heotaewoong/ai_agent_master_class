import streamlit as st
import asyncio
from agents import Agent, Runner, SQLiteSession, function_tool

# ---------------------------------------------------------
# 1. 도구(Tool) 만들기: 웹 검색 기능
# ---------------------------------------------------------
@function_tool
def web_search(query: str):
    """Search the web for motivational content, habits, and self-improvement tips."""
    # (초보자용 팁: 실제 검색 API를 붙이기 전까지는 이렇게 가짜(Mock) 데이터를 반환하도록 만듭니다.)
    print(f"👉 [코치가 검색 중입니다... 검색어: {query}]")
    return f"'{query}'에 대한 웹 검색 결과: 1. 작게 시작해서 성취감을 맛보세요. 2. 환경을 나에게 유리하게 세팅하세요. 3. 완벽함보다는 꾸준함이 중요합니다."

# ---------------------------------------------------------
# 2. 에이전트(AI) & 기억력(Session) 준비하기
# ---------------------------------------------------------
# 사용자의 대화를 기억할 데이터베이스 수첩을 만듭니다.
session = SQLiteSession("user_1", "life_coach_memory.db")

# 라이프 코치 에이전트를 채용합니다.
coach_agent = Agent(
    name="Life Coach",
    instructions="""당신은 유저를 따뜻하게 격려하고 동기를 부여하는 전문 라이프 코치입니다. 
    사용자가 목표를 달성할 수 있도록 실용적인 조언과 습관 형성 팁을 제공하세요. 
    전문적인 지식이 필요할 때는 반드시 web_search 도구를 사용해서 정보를 찾아보고 답변하세요.""",
    tools=[web_search]
)

# ---------------------------------------------------------
# 3. Streamlit UI (웹 화면) 그리기
# ---------------------------------------------------------
st.title("🌱 나의 전담 라이프 코치")
st.caption("어떤 목표든 말씀해보세요. 제가 도와드릴게요!")

# Streamlit 화면에 이전 채팅 기록을 보여주기 위한 공간을 만듭니다.
if "messages" not in st.session_state:
    st.session_state.messages = []

# 화면이 새로고침 될 때마다 이전 대화 내용을 화면에 다시 그려줍니다.
for message in st.session_state.messages:
    with st.chat_message(message["role"]):
        st.markdown(message["content"])

# ---------------------------------------------------------
# 4. 사용자 입력 받기 및 AI 실행하기
# ---------------------------------------------------------
# st.chat_input: 화면 맨 아래에 카카오톡 같은 채팅 입력창을 만듭니다.
if prompt := st.chat_input("이루고 싶은 목표나 고민을 적어주세요..."):
    
    # 1. 사용자가 입력한 메시지를 화면에 띄우고 기록에 저장합니다.
    with st.chat_message("user"):
        st.markdown(prompt)
    st.session_state.messages.append({"role": "user", "content": prompt})

    # 2. 코치(AI)가 생각하고 답변하는 부분입니다.
    with st.chat_message("assistant"):
        with st.spinner("코치가 답변을 준비하고 있습니다..."): # 빙글빙글 도는 로딩 애니메이션
            
            # Streamlit은 동기(Sync) 방식이고 Runner.run은 비동기(Async) 방식이라 
            # asyncio.run()으로 감싸서 실행해야 에러가 나지 않습니다.
            result = asyncio.run(
                Runner.run(
                    coach_agent, 
                    prompt, 
                    session=session # 코치에게 이전 기억 수첩을 쥐여줍니다.
                )
            )
            
            # 코치의 최종 답변을 화면에 띄웁니다.
            st.markdown(result.final_output)
            
    # 3. 코치의 답변도 채팅 기록에 저장합니다.
    st.session_state.messages.append({"role": "assistant", "content": result.final_output})
