# ============================================================
# NewsHub Agent — 환경변수 설정
# 이 파일을 .env 로 복사: copy .env.example .env
# ============================================================

# ──────────────────────────────────────────────────────────
# LLM 프로바이더 선택 (기본값: openai)
# ──────────────────────────────────────────────────────────
# 옵션: groq | ollama | gemini | openai
LLM_PROVIDER=groq

# ──────────────────────────────────────────────────────────
# ★ Groq — 완전 무료 (권장) ★
# 발급: https://console.groq.com → API Keys → Create API Key
# 무료 한도: llama-3.1-8b-instant 14,400 req/day
# ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
# 고품질 옵션: llama-3.3-70b-versatile (1,000 req/day)

# ──────────────────────────────────────────────────────────
# Ollama — 로컬 완전 무료 (API 키 불필요)
# 설치: https://ollama.com → ollama pull llama3.2
# ──────────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ──────────────────────────────────────────────────────────
# Google Gemini — 무료 티어 1500 req/day
# 발급: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIza-your-key
# GEMINI_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────────────
# OpenAI — 유료 (기존 사용자)
# ──────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────
# 웹 검색 (선택사항 — 없으면 DuckDuckGo 무료 자동 사용)
# ──────────────────────────────────────────────────────────
# Tavily: https://tavily.com → 무료 1000회/월
# 없어도 DuckDuckGo로 자동 전환됨
# TAVILY_API_KEY=tvly-your-key
